DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_application_client_id
DEV_GUILD_ID=your_test_guild_id
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp
YTDLP_COOKIES_FILE=
YTDLP_YOUTUBE_EXTRACTOR_ARGS=youtube:player_client=default,mweb
YTDLP_POT_PROVIDER_ARGS=youtubepot-bgutilhttp:base_url=http://bgutil-pot:4416;disable_innertube=1
LRCLIB_BASE_URL=https://lrclib.net
DEFAULT_VOLUME=100
DEFAULT_IDLE_TIMEOUT_MS=180000
EMPTY_CHANNEL_TIMEOUT_MS=180000
DEFAULT_SEARCH_PLATFORM=youtube
LOCAL_AUDIO_CACHE_DIR=./storage/audio-cache
LOCAL_AUDIO_CACHE_INDEX_FILE=./storage/audio-cache/index.json
LOCAL_AUDIO_CACHE_MAX_TRACKS=9000
LOCAL_AUDIO_CACHE_MAX_SIZE_BYTES=32212254720
LOCAL_AUDIO_CACHE_BITRATE_KBPS=128
LOCAL_AUDIO_CACHE_MAX_DURATION_SECONDS=600
